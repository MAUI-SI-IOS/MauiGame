<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiGame.MainPage">

    <Grid RowDefinitions="*, Auto">

        <!-- Game Canvas -->
        <GraphicsView x:Name="GameCanvas"
                      Grid.Row="0"
                      SizeChanged="OnGameCanvasSizeChanged" />

        <!-- UI Overlay (Game Over / Start Menu) -->
        <Grid Grid.Row="0"
              IsVisible="{Binding IsGameOver}"
              BackgroundColor="#80000000">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="20">
                <Button Text="Start Game"
                        Clicked="OnStartGameClicked"
                        FontSize="24"
                        WidthRequest="200"
                        HeightRequest="60" />
                <Button Text="Hall of Fame"
                        Clicked="OnHallOfFameClicked"
                        FontSize="20"
                        WidthRequest="200"
                        HeightRequest="50" />
            </VerticalStackLayout>
        </Grid>

        <!-- Controls -->
        <Grid Grid.Row="1" ColumnDefinitions="*, *, *" HeightRequest="100" BackgroundColor="#333333">
            <Button Grid.Column="0"
                    Text="PUNCH&#10;(vs Sword Down)"
                    Clicked="OnPunchClicked"
                    BackgroundColor="Blue"
                    Margin="5"
                    FontSize="18"
                    FontAttributes="Bold"/>

            <Button Grid.Column="1"
                    Text="PARRY&#10;(vs Sword Front)"
                    Clicked="OnParryClicked"
                    BackgroundColor="Green"
                    Margin="5"
                    FontSize="18"
                    FontAttributes="Bold"/>

            <Button Grid.Column="2"
                    Text="LOW KICK&#10;(vs Sword Up)"
                    Clicked="OnKickClicked"
                    BackgroundColor="Red"
                    Margin="5"
                    FontSize="18"
                    FontAttributes="Bold"/>
        </Grid>

    </Grid>

</ContentPage>
